{
	"$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
	"packages": [
		"nodejs@22"
	],
	"shell": {
		"init_hook": [
			"npm install --no-audit --no-fund"
		],
		"scripts": {
			"build": [
				"npm run build"
			],
			"dev": [
				"npm run dev"
			],
			"run": [
				"$@"
			]
		}
	}
}
